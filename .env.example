# Required
MASTER_KEY=            # 64 hex chars: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_SEED=         # family seed of your funded platform wallet (needs ~50+ XRP)

# Optional
XRPL_WSS=wss://xrplcluster.com
XUMM_API_KEY=
XUMM_API_SECRET=
LAUNCH_FEE_XRP=20
FUND_ISSUER_XRP=2
FUND_CURVE_XRP=5
PORT=3000
# TESTNET=1   # never set in production — enables faucet demo endpoints
